{
  "manifest_version": 3,
  "name": "AI Queue Iterator",
  "version": "0.1.0",
  "description": "Queue prompts and submit them sequentially on ChatGPT and Gemini web.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "downloads",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "AI Queue Iterator"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
